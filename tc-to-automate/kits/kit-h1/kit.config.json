{
  "id": "kit-h1",
  "extends": "kit-u1",
  "displayName": "Hybrid UI+API Greenfield — Playwright TS + API Client TS",
  "mode": "greenfield",
  "tech": {
    "language": "typescript",
    "testRunner": "playwright",
    "apiClient": "axios",
    "bddRunner": null,
    "bddRunnerBdd": "@cucumber/cucumber"
  },
  "testStyle": "non-bdd",
  "locatorStrategies": ["playwright-mcp", "dom-based", "ai-guided"],
  "reporting": ["playwright-html", "allure"],
  "inputs": {
    "supported": ["app-url", "test-cases", "dom-snapshot", "postman-collection", "openapi-spec"],
    "locatorRequired": true
  },
  "agents": {
    "locator": "./tc-to-automate/kits/_base/agents/locator-agent.md",
    "apiSpecParser": "./tc-to-automate/kits/kit-h1/agents/api-spec-parser-agent.md",
    "testGenerator": "./tc-to-automate/kits/kit-h1/agents/hybrid-test-generator-agent.md",
    "scaffolder": "./tc-to-automate/kits/kit-u1/agents/framework-setup-agent.md",
    "reporting": "./tc-to-automate/kits/_base/agents/reporting-agent.md"
  },
  "extraTemplates": "./tc-to-automate/kits/kit-h1/templates",
  "notes": "Extends Kit-U1 for UI layer. Adds API client (axios) and hybrid test generator that can combine UI actions with API calls (e.g., API setup then UI verify)."
}
